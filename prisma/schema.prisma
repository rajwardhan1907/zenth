// Prisma schema for Zenth
// DB connection not required to run locally — schema is ready for wiring

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  image     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sites    Site[]
  accounts Account[]
  sessions Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Site {
  id             String   @id @default(cuid())
  userId         String
  name           String
  domain         String
  gscConnected   Boolean  @default(false)
  healthScore    Int      @default(0)
  monthlyTraffic Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  keywords Keyword[]
  articles Article[]
}

model Keyword {
  id          String  @id @default(cuid())
  siteId      String
  keyword     String
  volume      Int
  difficulty  Int
  intent      String
  status      String
  currentRank Int?
  clusterId   String?
  clusterName String?

  site    Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  article Article?
}

model Article {
  id              String   @id @default(cuid())
  siteId          String
  keywordId       String?  @unique
  title           String
  wordCount       Int      @default(0)
  status          String   @default("draft")
  outline         Json?
  seoSignals      Json?
  trafficForecast Json?
  publishSettings Json?
  publishedAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  site    Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  keyword Keyword? @relation(fields: [keywordId], references: [id])
}

model AgentEvent {
  id          String   @id @default(cuid())
  siteId      String
  type        String
  title       String
  description String
  status      String   @default("queued")
  metadata    Json?
  createdAt   DateTime @default(now())
}
