# ─── Zenth environment variables ───────────────────────────────
#
# Copy this file to .env.local for local development.
# All variables marked [REQUIRED] must be set in Vercel dashboard
# before the first deploy. Variables marked [OPTIONAL] can be
# added later when that feature is built.

# Next.js
NEXTAUTH_URL=https://your-domain.com                   # [REQUIRED]
NEXTAUTH_SECRET=your-secret-here                       # [REQUIRED]

# App URL (used for metadata and open-graph base URL)
NEXT_PUBLIC_APP_URL=https://your-domain.com            # [REQUIRED]

# Internal API base URL (leave blank to use /api in production)
NEXT_PUBLIC_API_URL=https://your-domain.com            # [OPTIONAL]

# Database (Prisma + PostgreSQL)
DATABASE_URL=postgresql://user:pass@host:5432/zenth    # [REQUIRED]

# Google OAuth (for NextAuth Google provider)
GOOGLE_CLIENT_ID=your-google-client-id                 # [REQUIRED]
GOOGLE_CLIENT_SECRET=your-google-client-secret         # [REQUIRED]

# DataForSEO — https://app.dataforseo.com/api-access
DATAFORSEO_LOGIN=your-dataforseo-login-email           # [REQUIRED for Phase 3+]
DATAFORSEO_PASSWORD=your-dataforseo-api-password       # [REQUIRED for Phase 3+]

# Razorpay
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx                  # [REQUIRED]
RAZORPAY_KEY_SECRET=your-razorpay-secret               # [REQUIRED]
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx      # [REQUIRED]

# Twilio WhatsApp
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx  # [OPTIONAL]
TWILIO_AUTH_TOKEN=your-twilio-auth-token               # [OPTIONAL]
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886             # [OPTIONAL]

# Inngest
INNGEST_EVENT_KEY=your-inngest-event-key               # [OPTIONAL]
INNGEST_SIGNING_KEY=your-inngest-signing-key           # [OPTIONAL]

# Vercel Cron security
CRON_SECRET=your-cron-secret                           # [OPTIONAL]

# Anthropic (Claude API)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx          # [OPTIONAL]
