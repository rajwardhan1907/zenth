{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "installCommand": "npm install --legacy-peer-deps",
  "crons": [
    {
      "path": "/api/cron/rank-tracking",
      "schedule": "30 0 * * *"
    },
    {
      "path": "/api/cron/keyword-refresh",
      "schedule": "30 1 * * 1"
    },
    {
      "path": "/api/cron/site-audit",
      "schedule": "30 2 1 * *"
    }
  ]
}
